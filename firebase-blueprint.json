{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription/wallet data mapping to student profiles.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "verified": { "type": "boolean" },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "string" },
        "institution": { "type": "string" },
        "department": { "type": "string" },
        "matricNo": { "type": "string" },
        "userType": { "type": "string", "enum": ["student", "faculty", "organization", "general"] }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "DocumentCategory": {
      "title": "DocumentCategory",
      "description": "Premium document categories matching professional or academic drafts available.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "priceNGN": { "type": "number" },
        "requiredFields": { "type": "array" },
        "samplePreview": { "type": "string" },
        "aiPromptTemplate": { "type": "string" },
        "templateStyle": { "type": "string", "enum": ["classic", "modern", "minimal", "executive"] }
      },
      "required": ["id", "name", "description", "priceNGN", "requiredFields", "samplePreview", "aiPromptTemplate"]
    },
    "GeneratedDocument": {
      "title": "GeneratedDocument",
      "description": "Generated academic draft document generated by Gemini Pro and secured with QRs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "inputs": { "type": "object" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "letterheadName": { "type": "string" },
        "letterheadAddress": { "type": "string" },
        "letterheadLogo": { "type": "string" },
        "watermarkLogo": { "type": "string" },
        "letterheadLogoAlign": { "type": "string", "enum": ["left", "right", "center", "align-text"] },
        "watermarkLogoAlign": { "type": "string", "enum": ["left", "right", "center", "diagonal"] },
        "letterheadTitleColor": { "type": "string" },
        "letterheadLineColor": { "type": "string" },
        "letterheadLineStyle": { "type": "string", "enum": ["solid", "double", "dotted", "dashed", "none"] },
        "designPatternStyle": { "type": "string", "enum": ["standard-formal", "modern-side", "classic-academy", "executive-tech", "minimalist"] },
        "letterheadTitleSize": { "type": "string", "enum": ["sm", "md", "lg", "xl"] },
        "addWatermark": { "type": "boolean" },
        "addQrCode": { "type": "boolean" },
        "addSignatureLine": { "type": "boolean" },
        "signerName": { "type": "string" },
        "signerTitle": { "type": "string" },
        "paid": { "type": "boolean" },
        "paymentGateway": { "type": "string", "enum": ["paystack", "monnify", "flutterwave"] },
        "paymentRef": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "categoryId", "categoryName", "inputs", "title", "content", "paid", "createdAt"]
    },
    "PaymentRecord": {
      "title": "PaymentRecord",
      "description": "Payment transactions for invoice/wallet topups or paper checkout audits.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "categoryId": { "type": "string" },
        "categoryName": { "type": "string" },
        "amount": { "type": "number" },
        "gateway": { "type": "string", "enum": ["paystack", "monnify", "flutterwave"] },
        "reference": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "reference", "status", "createdAt"]
    },
    "SampleResearchTemplate": {
      "title": "SampleResearchTemplate",
      "description": "A structure/scanned model uploaded by admin to guide AI draft consistency.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "categoryId": { "type": "string" },
        "title": { "type": "string" },
        "organization": { "type": "string" },
        "rawText": { "type": "string" },
        "structureAnalysis": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "categoryId", "title", "rawText", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Col containing user profiles."
    },
    "/categories/{categoryId}": {
      "schema": "DocumentCategory",
      "description": "Col containing master categories available to draft."
    },
    "/documents/{documentId}": {
      "schema": "GeneratedDocument",
      "description": "Col containing official and academic generated drafts."
    },
    "/payments/{paymentId}": {
      "schema": "PaymentRecord",
      "description": "Col containing ledger checkout payments."
    },
    "/researchTemplates/{templateId}": {
      "schema": "SampleResearchTemplate",
      "description": "Col containing admin research analyzer baseline model templates."
    }
  }
}
