{
  "entities": {
    "cert_requests": {
      "title": "Certificate Inquiries & Applications",
      "description": "User requests for state identification or origin certificates",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "dob": { "type": "string" },
        "stateOfOrigin": { "type": "string" },
        "localGovernment": { "type": "string" },
        "purpose": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "certificateNumber": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["fullName", "email", "dob", "stateOfOrigin", "localGovernment", "purpose", "status", "userId"]
    },
    "quizzes": {
      "title": "Nigerian Geography/State Quiz Results",
      "description": "Results of quizzes taken by users about Nigerian states",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "percentage": { "type": "number" },
        "category": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "score", "total", "percentage", "category"]
    }
  },
  "firestore": {
    "/cert_requests/{requestId}": {
      "schema": "cert_requests",
      "description": "Collection of certificate applications"
    },
    "/quizzes/{quizId}": {
      "schema": "quizzes",
      "description": "Collection of quiz scores"
    }
  }
}
